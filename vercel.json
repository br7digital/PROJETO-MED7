{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/ortopedista/assets/(.*)",
      "destination": "/ortopedista/dist/assets/$1"
    },
    {
      "source": "/ortopedista/:path*",
      "destination": "/ortopedista/dist/index.html"
    }
  ]
}
